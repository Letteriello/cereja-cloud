# Environment Variables Example - Telegram Bot
# Copy this to .env and fill in your values

# Required
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyzYZabcdefghij

# Webhook Configuration (recommended for production)
WEBHOOK_MODE=true
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook/telegram

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Multi-tenant Configuration (optional)
# Format: chat_id1:tenant_id1,chat_id2:tenant_id2
TENANT_MAP=123456789:CerejaOS_Enterprise,987654321:Acme_Corp

# Orquestrador API (for forwarding messages)
ORQUESTRADOR_URL=http://orquestrador:8000
ORQUESTRADOR_API_KEY=your_api_key_here
